PUBLIC_STRIPE_KEY=pk_test
VITE_GRPC_API_URL=http://localhost:50051
VITE_REST_API_URL=http://localhost:3000
VITE_STRIPE_PRO_PRICE_ID=price_xxx

# Sentry — leave the DSNs empty to disable Sentry locally.
PUBLIC_SENTRY_WEB_DSN=
PUBLIC_SENTRY_ENVIRONMENT=
PUBLIC_SENTRY_RELEASE=

# Server-side Sentry (used by instrumentation.server.ts and hooks.server.ts).
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# Build-time only; required to upload source maps. Do not commit real values.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
