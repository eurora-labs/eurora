<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSUIElement</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<!-- The launcher dials the desktop bridge over plaintext
		     ws://localhost:1431/bridge. ATS treats unqualified hostnames
		     as local resources; NSAllowsLocalNetworking is the narrow,
		     Apple-blessed knob to permit non-TLS loads to them without
		     loosening anything else. See BridgeProtocol.swift for the
		     transport rationale. -->
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>SFSafariWebExtensionConverterVersion</key>
	<string>26.2</string>
</dict>
</plist>
