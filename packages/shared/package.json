{
	"name": "@eurora/shared",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "tsc --noEmit",
		"test": "vitest run --mode development",
		"test:watch": "vitest --watch --mode development"
	},
	"devDependencies": {
		"typescript": "^5.9.3",
		"vite": "catalog:",
		"vite-plugin-dts": "^4.5.4",
		"vitest": "catalog:"
	},
	"exports": {
		"./bindings/*": {
			"import": "./dist/bindings/*.js",
			"types": "./dist/bindings/*.d.ts"
		},
		"./*": {
			"import": "./dist/*.js",
			"types": "./dist/*.d.ts"
		}
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	]
}
