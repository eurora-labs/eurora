{
	"name": "root",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "turbo run build ",
		"build:desktop": "turbo run build --filter @eurora/desktop...",
		"dev": "turbo run dev",
		"lint": "turbo run //#globallint --no-daemon",
		"check-types": "turbo run check-types",
		"dev:monolith": "cargo watch -x 'run -p be-monolith -- --mode development'",
		"prod:monolith": "cargo run -p be-monolith -- --mode production",
		"docker:monolith": "./scripts/build-monolith-image.sh --restart",
		"dev:desktop": "pnpm tauri dev",
		"dev:mobile:android": "pnpm tauri android dev --config crates/app/euro-mobile/tauri.conf.json",
		"dev:mobile:ios": "pnpm tauri ios dev --config crates/app/euro-mobile/tauri.conf.json",
		"build:mobile:android": "pnpm tauri android build --config crates/app/euro-mobile/tauri.conf.json",
		"build:mobile:ios": "pnpm tauri ios build --config crates/app/euro-mobile/tauri.conf.json",
		"dev:ui": "pnpm --filter @eurora/ui storybook",
		"check": "turbo run check --no-daemon",
		"build:ui": "turbo run build --filter @eurora/ui...",
		"build:test": "pnpm exec tauri build --config crates/app/euro-tauri/tauri.conf.test.json -- --profile dev",
		"build:browser": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:all",
		"build:firefox": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:firefox",
		"build:chrome": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:chrome",
		"build:edge": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:edge",
		"dev:chrome": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:chrome:dev",
		"dev:edge": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:edge:dev",
		"dev:firefox": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:firefox:dev",
		"build:safari": "turbo run build --filter @eurora/browser^... && pnpm --filter @eurora/browser run build:safari",
		"dev:web": "pnpm --filter @eurora/web dev",
		"dev:web:watch": "pnpm --filter @eurora/ui package && concurrently \"pnpm --filter @eurora/ui dev:watch\" \"pnpm --filter @eurora/web dev\" --names \"ui,web\" --prefix-colors \"blue,green\"",
		"build:web": "turbo run build --filter @eurora/web...",
		"prod:web": "pnpm build:web && serve -l 4173 apps/web/dist",
		"dev:docs": "pnpm --filter @eurora/docs dev",
		"tauri": "tauri",
		"dev:internal-tauri": "turbo watch --filter @eurora/desktop dev",
		"commit": "cz",
		"proto:typescript": "buf generate && turbo run build --filter @eurora/shared --force",
		"proto:rust": "cargo build -p proto-gen",
		"proto:swift": "protoc --proto_path=proto --swift_out=apps/macos/Shared/Generated --plugin=protoc-gen-grpc-swift=$(which protoc-gen-grpc-swift-2) --grpc-swift_out=apps/macos/Shared/Generated proto/browser_bridge.proto",
		"prettier": "prettier --check",
		"fix": "eslint --fix .",
		"format": "prettier --write .",
		"rustfmt": "cargo +nightly fmt -- --config-path rustfmt-nightly.toml",
		"generate:licenses": "scripts/generate-licenses",
		"test": "turbo run test --no-daemon",
		"test:watch": "pnpm --filter @eurora/desktop run test:watch",
		"test:e2e:web": "turbo run test:e2e:web",
		"test:e2e:blackbox": "pnpm --filter @eurora/e2e run test:e2e:blackbox",
		"test:e2e:webextension": "turbo run test:e2e:webextension"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.66.0",
		"@bufbuild/protobuf": "^2.11.0",
		"@bufbuild/protoc-gen-es": "^2.11.0",
		"@commitlint/cli": "^19.8.1",
		"@commitlint/config-conventional": "^19.8.1",
		"@commitlint/cz-commitlint": "^19.8.1",
		"@connectrpc/connect": "^2.1.1",
		"@connectrpc/connect-web": "^2.1.1",
		"@eslint/js": "^9.39.3",
		"@gitbutler/no-relative-imports": "^0.0.3",
		"@tauri-apps/cli": "^2.10.1",
		"commitizen": "^4.3.1",
		"concurrently": "^9.2.1",
		"cz-conventional-changelog": "^3.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-next": "^0.6.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-storybook": "10.2.15",
		"eslint-plugin-svelte": "3.9.0",
		"globals": "^16.5.0",
		"husky": "^9.1.7",
		"inquirer": "^9.3.8",
		"postcss": "catalog:",
		"prettier": "^3.8.1",
		"prettier-plugin-css-order": "^2.2.0",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"protolint": "^0.56.4",
		"svelte-eslint-parser": "^1.5.1",
		"tailwindcss": "catalog:",
		"ts-proto": "^2.11.4",
		"turbo": "^2.8.20",
		"typescript-eslint": "^8.56.1",
		"web-ext": "^8.10.0"
	},
	"packageManager": "pnpm@10.33.0",
	"engines": {
		"node": ">=20.11"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		],
		"overrides": {
			"tar": ">=7.5.8",
			"node-forge": ">=1.3.2",
			"flatted": ">=3.4.0",
			"minimatch": ">=3.1.3",
			"@isaacs/brace-expansion": ">=5.0.1",
			"serialize-javascript": ">=7.0.3",
			"form-data": ">=4.0.4",
			"rollup": ">=4.59.0",
			"undici": ">=7.24.0",
			"cookie": ">=0.7.0",
			"devalue": ">=5.6.4",
			"tmp": ">=0.2.4",
			"wdio-video-reporter>glob": ">=11.1.0",
			"effect": ">=3.20.0",
			"fast-xml-parser": ">=5.5.7",
			"lodash": ">=4.17.23",
			"mdast-util-to-hast": ">=13.2.1"
		}
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"husky": {
		"hooks": {
			"prepare-commit-msg": "exec < /dev/tty && npx cz --hook || true"
		}
	}
}
