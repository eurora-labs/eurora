# Eurora local environment — single source of truth.
#
# Quickstart:
#   cp .env.example .env
#   $EDITOR .env        # paste OPENAI_API_KEY
#   just dev            # Postgres + backend + web + desktop
#
# `just` loads this file and propagates every variable to the
# backend, the SvelteKit web/desktop bundles (via Vite's `envDir`),
# and the mobile build (baked at compile time by build.rs). Do not
# add per-app .env files; one root file is the contract.
#
# All sensible defaults — JWT secrets, dev Postgres URL, dev CORS,
# asset storage — are baked into debug builds. The only value
# `just dev` needs you to set is `OPENAI_API_KEY`.

# ============================================================================
# REQUIRED — LLM provider
# ============================================================================

OPENAI_API_KEY=sk-...

# Model used for both chat and title generation. Override individually with
# EURORA_TITLE_MODEL if you want a cheaper title model.
EURORA_CHAT_MODEL=gpt-4o-mini
# EURORA_TITLE_MODEL=gpt-4o-mini

# Optional: enable image-bearing messages by pointing a vision-capable model
# at the same OpenAI account.
# EURORA_VISION_MODEL=gpt-4o

# Optional: talk to a generic OpenAI-compatible server (Ollama, LM Studio,
# vLLM, …) instead of OpenAI. Replace the OPENAI block above with these:
# EURORA_LLM_KIND=openai_compatible
# EURORA_LLM_BASE_URL=http://localhost:11434/v1
# EURORA_LLM_API_KEY=                          # leave blank for keyless servers
# EURORA_CHAT_MODEL=llama3.2

# ============================================================================
# Web frontend (apps/web) — Vite-exposed
# ============================================================================
#
# `VITE_*` and `PUBLIC_*` are exposed to client-side code by Vite/SvelteKit.
# Bare names below stay server-side only.

VITE_API_URL=http://localhost:3000

# Stripe (only needed if you're testing the upgrade flow locally).
# PUBLIC_STRIPE_KEY=pk_test_...
# VITE_STRIPE_PRO_PRICE_ID=price_...

# Sentry — leave blank to disable. The DSN-bearing vars are read by the
# running app; the SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT trio is
# build-time only (used by the Vite plugin to upload source maps). Do not
# commit real values to a shared .env.
# PUBLIC_SENTRY_WEB_DSN=
# PUBLIC_SENTRY_ENVIRONMENT=
# PUBLIC_SENTRY_RELEASE=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# SENTRY_RELEASE=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# ============================================================================
# Desktop / mobile escape hatches — debug-only overrides
# ============================================================================
#
# In normal use the desktop app picks its backend via the connection mode
# in app settings (Cloud / Local / Custom). Setting EURORA_API_BASE_URL
# in this file forces the app to talk to that URL on this run regardless
# of the persisted setting (the persisted value is left untouched).
#
# EURORA_AUTH_SERVICE_URL points at the OAuth/login page; in dev that's
# the SvelteKit web app `pnpm dev:web` serves at :5173.
#
# Mobile bakes these into the binary at build time via build.rs.

# EURORA_API_BASE_URL=http://localhost:3000
# EURORA_AUTH_SERVICE_URL=http://localhost:5173
# EURORA_REST_API_URL=http://localhost:3000

# ============================================================================
# Backend overrides — debug builds default these; only set to override
# ============================================================================
#
# `just dev:backend` runs `cargo run -p be-monolith` natively against the
# Postgres started by docker-compose. In a debug build:
#
#   - REMOTE_DATABASE_URL defaults to docker-compose's local Postgres
#   - JWT_ACCESS_SECRET / JWT_REFRESH_SECRET default to stable placeholders
#   - WEB_ALLOWED_ORIGINS defaults to localhost (5173) + tauri://localhost
#   - AUTH_COOKIE_SECURE defaults to false (no TLS in dev)
#   - ASSET_STORAGE_BACKEND defaults to fs at ../assets
#
# Release builds refuse to start without REMOTE_DATABASE_URL and the JWT
# secrets — placeholder values would be a production-grade footgun.
#
# Uncomment any of these only if you need to override the dev defaults.

# REMOTE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eurora
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# WEB_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost
# AUTH_COOKIE_SECURE=false
# ASSET_STORAGE_BACKEND=fs
# ASSET_STORAGE_FS_ROOT=../assets

# Optional: change the Postgres host port docker-compose binds to. Useful
# if you already run a Postgres on 5432.
# EURORA_POSTGRES_PORT=5432
