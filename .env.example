# Eurora local environment.
#
# Copy this file to `.env` and fill in your `OPENAI_API_KEY`. That is the
# only value the `just dev` flow needs from you.
#
#   cp .env.example .env
#   $EDITOR .env
#   just dev
#
# Everything else (database URL, JWT secrets, dev-mode toggles) is set by
# `docker-compose.yml` or has sensible defaults baked into the binary.

# ---------------------------------------------------------------------------
# LLM provider (required)
# ---------------------------------------------------------------------------

OPENAI_API_KEY=sk-...

# Model used for both chat and title generation. Override individually with
# EURORA_TITLE_MODEL if you want a cheaper title model.
EURORA_CHAT_MODEL=gpt-4o-mini
# EURORA_TITLE_MODEL=gpt-4o-mini

# Optional: enable image-bearing messages by pointing a vision-capable model
# at the same OpenAI account.
# EURORA_VISION_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Pointing at a generic OpenAI-compatible server (Ollama, LM Studio, vLLM, ...)
# ---------------------------------------------------------------------------
#
# Replace the section above with the four lines below if you want to talk to
# a local OpenAI-compatible server instead of OpenAI itself.
#
# EURORA_LLM_KIND=openai_compatible
# EURORA_LLM_BASE_URL=http://localhost:11434/v1
# EURORA_LLM_API_KEY=                          # leave blank for keyless servers
# EURORA_CHAT_MODEL=llama3.2

# ---------------------------------------------------------------------------
# Backend runtime
# ---------------------------------------------------------------------------
#
# `just dev:backend` runs `cargo run -p be-monolith` natively against the
# Postgres started by docker-compose, so the binary needs the database URL
# and JWT secrets in its env. These defaults match `docker-compose.yml`.

REMOTE_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eurora
JWT_ACCESS_SECRET=dev_access_secret
JWT_REFRESH_SECRET=dev_refresh_secret
WEB_ALLOWED_ORIGINS=http://localhost:5173,tauri://localhost
AUTH_COOKIE_SECURE=false
ASSET_STORAGE_BACKEND=fs
ASSET_STORAGE_FS_ROOT=./assets
