# ─── LLM ─────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=sk-...
EURORA_CHAT_MODEL=gpt-4o-mini
# EURORA_TITLE_MODEL=gpt-4o-mini
# EURORA_VISION_MODEL=gpt-4o

# Or point at an OpenAI-compatible server (Ollama, LM Studio, vLLM, …):
# EURORA_LLM_KIND=openai_compatible
# EURORA_LLM_BASE_URL=http://localhost:11434/v1
# EURORA_LLM_API_KEY=
# EURORA_CHAT_MODEL=llama3.2

# ─── Backend ─────────────────────────────────────────────────────────────────

REMOTE_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/eurora

# BACKEND_URL and WEB_URL default to localhost via the justfile. Override
# them here only if you need a different host for local dev (e.g. binding
# the backend to a non-default port). CI sets them via workflow `env:`.

# Production MUST replace these with `openssl rand -hex 32`.
JWT_ACCESS_SECRET=dev_jwt_access_secret_DO_NOT_USE_IN_PROD
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_DO_NOT_USE_IN_PROD

AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=
# TRUSTED_PROXIES=

AUTHZ_MODEL_PATH=config/authz/model.conf
AUTHZ_POLICY_PATH=config/authz/policy.csv

ASSET_STORAGE_BACKEND=fs
ASSET_STORAGE_FS_ROOT=../assets
# ASSET_STORAGE_S3_BUCKET=
# ASSET_STORAGE_S3_REGION=
# ASSET_STORAGE_S3_ENDPOINT=
# ASSET_STORAGE_S3_ACCESS_KEY_ID=
# ASSET_STORAGE_S3_SECRET_ACCESS_KEY=

# ─── Optional services ───────────────────────────────────────────────────────

# LETTERMINT_API_TOKEN=
# LETTERMINT_SENDER=Eurora <noreply@eurora-labs.com>

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback
# Mobile flow: backend lands the OAuth callback here (instead of the web SPA)
# and 302s to `eurora://mobile/callback`. Must be added to the Google
# OAuth client's authorised redirect URIs.
# GOOGLE_MOBILE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/mobile-callback
# Native iOS sign-in (GoogleSignIn SDK) issues ID tokens whose `aud` is
# the iOS OAuth client ID. When set, the backend accepts that audience
# alongside `GOOGLE_CLIENT_ID` for ID-token verification, and the mobile
# binary bakes it for use as the SDK's `clientID`.
# GOOGLE_CLIENT_ID_IOS=

# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_REDIRECT_URI=http://localhost:3000/auth/oauth/github/callback
# GITHUB_MOBILE_REDIRECT_URI=http://localhost:3000/auth/oauth/github/mobile-callback

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=
# PUBLIC_STRIPE_KEY=pk_test_...
# VITE_STRIPE_PRO_PRICE_ID=price_...

# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com

# SENTRY_MONOLITH_DSN=
# SENTRY_SEND_PII=false
# SENTRY_DEBUG=false

# ─── Web app — Sentry ────────────────────────────────────────────────────────
# These names MUST exist in the build env (they're `$env/static/public` named
# imports in apps/web). Empty values are fine — Sentry is silently disabled.
# Use the same DSN value the Sentry "javascript-sveltekit" project gives you;
# it's used by both client and server.
# PUBLIC_SENTRY_WEB_DSN=
# PUBLIC_SENTRY_ENVIRONMENT=
# PUBLIC_SENTRY_RELEASE=

# Source-map upload (build-time only; leave blank to skip upload).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# EURORA_DESKTOP_SENTRY_DSN=
# EURORA_DESKTOP_POSTHOG_KEY=
# EURORA_DESKTOP_POSTHOG_HOST=
# EURORA_RELEASE_CHANNEL=
