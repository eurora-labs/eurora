# ============================================================================
# Eurora local environment — single source of truth.
# ============================================================================
#
# Quickstart:
#   just init           # creates .env from this file, installs JS deps
#   $EDITOR .env        # paste OPENAI_API_KEY (the only required edit)
#   just dev            # Postgres + backend + web + desktop
#
# Every operational knob the project reads lives in this file. The
# justfile loads it via `set dotenv-load` and propagates the variables
# to every child process — backend, SvelteKit web/desktop (via Vite's
# `envDir`), docker-compose, and the mobile build (baked at compile
# time by build.rs). One file is the contract; do not add per-app
# .env files.
#
# In-source fallbacks have been removed. If a required variable is
# missing, the binary refuses to start with a clear error pointing
# back here — so dev and prod run the same code path. Override a
# value by editing your .env, never by adding fallback logic to source.

# ============================================================================
# REQUIRED — paste your OpenAI API key
# ============================================================================
#
# The only value `just dev` needs you to edit. Everything below has
# a working dev default.

OPENAI_API_KEY=sk-...

# Model used for both chat and title generation. Override the title
# model individually with EURORA_TITLE_MODEL if you want a cheaper one.
EURORA_CHAT_MODEL=gpt-4o-mini
# EURORA_TITLE_MODEL=gpt-4o-mini

# Optional: enable image-bearing messages by pointing a vision-capable
# model at the same OpenAI account.
# EURORA_VISION_MODEL=gpt-4o

# Optional: talk to a generic OpenAI-compatible server (Ollama, LM
# Studio, vLLM, …) instead of OpenAI. Replace the OPENAI_API_KEY
# block above with these:
# EURORA_LLM_KIND=openai_compatible
# EURORA_LLM_BASE_URL=http://localhost:11434/v1
# EURORA_LLM_API_KEY=
# EURORA_CHAT_MODEL=llama3.2

# ============================================================================
# Postgres (docker-compose + backend)
# ============================================================================
#
# docker-compose reads POSTGRES_{USER,PASSWORD,DB} when it provisions
# the container; the backend reads REMOTE_DATABASE_URL. Keep them in
# sync — if you change the credentials, update the URL too.
#
# EURORA_POSTGRES_PORT is the host port docker-compose binds to. The
# default (5433) avoids clashing with a system-installed Postgres on
# 5432.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=eurora
EURORA_POSTGRES_PORT=5433

REMOTE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/eurora

# ============================================================================
# Backend — HTTP, JWT, CORS, cookies
# ============================================================================
#
# Production deploys MUST replace JWT_*_SECRET with high-entropy random
# strings (>= 32 bytes); the `_DO_NOT_USE_IN_PROD` suffix is a
# deliberate audit-grep flag.
#
# AUTH_COOKIE_SECURE is `false` in dev because the local stack runs
# without TLS. Production MUST set it to `true` so cookies are only
# sent over HTTPS.

HTTP_ADDR=0.0.0.0:3000

JWT_ACCESS_SECRET=dev_jwt_access_secret_DO_NOT_USE_IN_PROD
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_DO_NOT_USE_IN_PROD

# Comma-separated `scheme://host[:port]` origins allowed to make
# credentialed `fetch` calls. Includes the SvelteKit dev server (5173),
# the backend itself (3000), and Tauri's webview origin.
WEB_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,tauri://localhost

AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=                    # set when subdomains share a session

# Comma-separated list of trusted reverse-proxy IPs / CIDR ranges
# allowed to set `X-Forwarded-For`. Empty (the default) means the
# socket peer IP is authoritative.
# TRUSTED_PROXIES=

# ============================================================================
# Backend — authorization (Casbin)
# ============================================================================
#
# Paths are resolved relative to the backend's working directory (the
# repo root when you run via `cargo run -p be-monolith`). The Dockerfile
# remaps these to `/etc/eurora/authz/...` for container deploys.

AUTHZ_MODEL_PATH=config/authz/model.conf
AUTHZ_POLICY_PATH=config/authz/policy.csv

# ============================================================================
# Backend — asset storage
# ============================================================================
#
# Dev uses a filesystem backend at ../assets (relative to the backend's
# CWD), keeping uploaded assets outside the repo tree. Switch to S3 by
# setting ASSET_STORAGE_BACKEND=s3 and uncommenting the S3 block below.

ASSET_STORAGE_BACKEND=fs
ASSET_STORAGE_FS_ROOT=../assets

# S3 backend (set ASSET_STORAGE_BACKEND=s3 and uncomment):
# ASSET_STORAGE_S3_BUCKET=
# ASSET_STORAGE_S3_REGION=
# ASSET_STORAGE_S3_ENDPOINT=             # for S3-compatible servers (MinIO, R2, …)
# ASSET_STORAGE_S3_ACCESS_KEY_ID=
# ASSET_STORAGE_S3_SECRET_ACCESS_KEY=

# ============================================================================
# Backend — outbound URLs
# ============================================================================
#
# Where the backend points users when it sends them off-site: Stripe
# success/cancel URLs, password-reset emails, OAuth completion landings.
# In dev that's the SvelteKit web app `pnpm dev:web` serves at :5173.

FRONTEND_URL=http://localhost:5173

# ============================================================================
# Web frontend (apps/web) — Vite-exposed
# ============================================================================
#
# `VITE_*` and `PUBLIC_*` are exposed to client-side code by
# Vite/SvelteKit. Bare names below stay server-side only.

VITE_API_URL=http://localhost:3000

# Stripe (only needed if you're testing the upgrade flow locally):
# PUBLIC_STRIPE_KEY=pk_test_...
# VITE_STRIPE_PRO_PRICE_ID=price_...

# ============================================================================
# Desktop / mobile — build-time bake-ins
# ============================================================================
#
# These are baked into the desktop and mobile binaries at compile time
# by build.rs. Override here if you are recompiling the project to
# point at your own organization's infrastructure — production URLs are
# NOT hardcoded in source.
#
#   EURORA_CLOUD_API_URL    URL the binary uses when the user picks
#                           "Cloud" connection mode in app settings.
#   EURORA_LOCAL_API_URL    URL the binary uses when the user picks
#                           "Local" connection mode (a localhost backend
#                           the user runs themselves).
#   EURORA_AUTH_SERVICE_URL OAuth/login landing page.

EURORA_CLOUD_API_URL=https://api.eurora-labs.com
EURORA_LOCAL_API_URL=http://localhost:3000
EURORA_AUTH_SERVICE_URL=http://localhost:5173

# ============================================================================
# Desktop / mobile — runtime escape hatches
# ============================================================================
#
# Normally the desktop app picks its backend via the connection mode in
# app settings (Cloud / Local / Custom). Setting EURORA_API_BASE_URL
# forces the app to talk to that URL on this run regardless of the
# persisted setting (the persisted value is left untouched). Mobile
# bakes these at compile time via build.rs; they have no effect on a
# running mobile binary.

# EURORA_API_BASE_URL=http://localhost:3000
# EURORA_REST_API_URL=http://localhost:3000

# ============================================================================
# Optional services — leave commented to disable in dev
# ============================================================================

# Email (Lettermint). Disabled in debug builds; release builds require
# both. The sender must be a verified Lettermint identity.
# LETTERMINT_API_TOKEN=
# LETTERMINT_SENDER=Eurora <noreply@eurora-labs.com>

# Google OAuth (set all three to enable the "Sign in with Google" flow):
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/auth/oauth/google/callback

# PostHog analytics — leave the key blank to disable. When the key is
# set, the host is required (the EU cloud is a sensible default).
# POSTHOG_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com

# Sentry — backend (release-only):
# SENTRY_MONOLITH_DSN=
# SENTRY_SEND_PII=false
# SENTRY_DEBUG=false

# Sentry — web frontend (Vite). Runtime DSN vars are read by the
# running app; the AUTH_TOKEN / ORG / PROJECT trio is build-time only
# (used by the Vite plugin to upload source maps). Do not commit real
# values to a shared .env.
# PUBLIC_SENTRY_WEB_DSN=
# PUBLIC_SENTRY_ENVIRONMENT=
# PUBLIC_SENTRY_RELEASE=
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=
# SENTRY_RELEASE=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Sentry / PostHog — desktop binary (baked at compile time by
# crates/app/euro-tauri/build.rs). Empty values disable telemetry.
# EURORA_DESKTOP_SENTRY_DSN=
# EURORA_DESKTOP_POSTHOG_KEY=
# EURORA_DESKTOP_POSTHOG_HOST=
# EURORA_RELEASE_CHANNEL=
