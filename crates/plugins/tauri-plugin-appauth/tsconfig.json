{
	"compilerOptions": {
		"strict": true,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"lib": ["ES2022"],
		"declaration": true,
		"declarationDir": "dist-js",
		"outDir": "dist-js",
		"rootDir": "guest-js",
		"skipLibCheck": true,
		"esModuleInterop": true
	},
	"include": ["guest-js/**/*.ts"]
}
