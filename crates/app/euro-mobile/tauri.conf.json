{
	"productName": "Eurora Mobile Dev",
	"identifier": "com.eurora-labs.eurora.mobile.dev",
	"mainBinaryName": "eurora-mobile",
	"build": {
		"beforeDevCommand": "pnpm --filter @eurora/mobile dev",
		"beforeBuildCommand": "pnpm --filter @eurora/mobile build",
		"frontendDist": "../../../apps/mobile/build",
		"devUrl": "http://localhost:1421"
	},
	"bundle": {
		"active": false,
		"category": "DeveloperTool",
		"copyright": "Copyright © 2024-2026 Eurora Labs. All rights reserved.",
		"targets": ["app"],
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"iOS": {
			"minimumSystemVersion": "15.0"
		}
	},
	"app": {
		"withGlobalTauri": false,
		"security": {
			"csp": {
				"default-src": "'self'",
				"img-src": "'self' asset: https://asset.localhost data: tauri://localhost https://avatars.githubusercontent.com https://*.eurora.com https://eurora-public.s3.amazonaws.com https://*.gravatar.com https://*.googleusercontent.com",
				"connect-src": "'self' ipc: http://ipc.localhost https://api.eurora.com",
				"script-src": "'self'",
				"font-src": "'self' data:",
				"style-src": "'self' 'unsafe-inline'"
			}
		}
	}
}
