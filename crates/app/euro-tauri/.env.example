# Tauri-app .env. Copy to `.env` for development.
#
# In normal use the desktop app picks its backend via the connection mode
# in app settings (Cloud / Local / Custom). The variables below are
# **debug-only escape hatches** read at startup.

# Override the persisted connection mode for this run only. The persisted
# setting is left untouched. Use this when iterating on a backend running
# at a non-default port.
# API_BASE_URL=http://localhost:3000

# Where the OAuth/login page is served from. The web auth UI runs at 5173
# under `pnpm dev:web` in dev; in production the app loads it from
# https://www.eurora-labs.com.
AUTH_SERVICE_URL=http://localhost:5173
