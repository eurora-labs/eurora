# insta writes `*.snap.new` (and historically `*.snap.pending`) next to
# accepted snapshots when it detects a diff. The user reviews them via
# `cargo insta review`, which renames the accepted ones to `*.snap`.
# These intermediate files are per-run and must not be committed.
tests/snapshots/*.snap.new
tests/snapshots/*.snap.pending

# trybuild writes failing stderr captures to a `wip/` directory under
# the crate root. The expected workflow is to inspect them and move
# accepted ones into `tests/fail/*.stderr` — the `wip/` directory
# itself is transient.
wip/
