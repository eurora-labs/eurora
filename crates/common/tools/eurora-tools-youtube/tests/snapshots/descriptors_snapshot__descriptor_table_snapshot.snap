---
source: crates/common/tools/eurora-tools-youtube/tests/descriptors_snapshot.rs
expression: wire
---
[
    WireToolDescriptor {
        definition: ToolDefinition {
            name: "browser::youtube::get_current_timestamp",
            description: "Return the user's current playback position in the active YouTube video, along with the video duration and play/pause state.",
            parameters: Object {
                "$schema": String("https://json-schema.org/draft/2020-12/schema"),
                "description": String("No arguments."),
                "title": String("Empty"),
                "type": String("object"),
            },
        },
        output_schema: Object {
            "$schema": String("https://json-schema.org/draft/2020-12/schema"),
            "description": String("Current playback state of the active YouTube video."),
            "properties": Object {
                "duration_seconds": Object {
                    "description": String("Total video length in seconds, possibly fractional."),
                    "format": String("double"),
                    "type": String("number"),
                },
                "playing": Object {
                    "description": String("`true` when the video is playing, `false` when paused."),
                    "type": String("boolean"),
                },
                "timestamp_seconds": Object {
                    "description": String("Playback position in seconds, possibly fractional."),
                    "format": String("double"),
                    "type": String("number"),
                },
                "video_id": Object {
                    "description": String("The YouTube video ID — the `v=` parameter from the watch URL."),
                    "type": String("string"),
                },
            },
            "required": Array [
                String("video_id"),
                String("timestamp_seconds"),
                String("duration_seconds"),
                String("playing"),
            ],
            "title": String("CurrentTimestamp"),
            "type": String("object"),
        },
        timeout_ms: 2000,
        source: Bridge {
            app_kind: "browser",
        },
        required_contexts: [
            "youtube::watch_page",
        ],
        requires_user_approval: false,
    },
    WireToolDescriptor {
        definition: ToolDefinition {
            name: "browser::youtube::get_transcript",
            description: "Return the full transcript of the video the user is watching. Comes from YouTube's caption API; videos without captions fail with a structured error.",
            parameters: Object {
                "$schema": String("https://json-schema.org/draft/2020-12/schema"),
                "description": String("No arguments."),
                "title": String("Empty"),
                "type": String("object"),
            },
        },
        output_schema: Object {
            "$defs": Object {
                "TranscriptEntry": Object {
                    "description": String("One cue from a YouTube transcript."),
                    "properties": Object {
                        "duration_seconds": Object {
                            "description": String("How long the cue is on screen, in seconds."),
                            "format": String("double"),
                            "type": String("number"),
                        },
                        "start_seconds": Object {
                            "description": String("Start time of the cue in seconds, relative to the video start."),
                            "format": String("double"),
                            "type": String("number"),
                        },
                        "text": Object {
                            "description": String("Cue text as YouTube serves it (HTML-escaped, single-language)."),
                            "type": String("string"),
                        },
                    },
                    "required": Array [
                        String("start_seconds"),
                        String("duration_seconds"),
                        String("text"),
                    ],
                    "type": String("object"),
                },
            },
            "$schema": String("https://json-schema.org/draft/2020-12/schema"),
            "description": String("Full transcript of a YouTube video."),
            "properties": Object {
                "entries": Object {
                    "description": String("Ordered cues; empty for videos with auto-captions disabled."),
                    "items": Object {
                        "$ref": String("#/$defs/TranscriptEntry"),
                    },
                    "type": String("array"),
                },
                "language": Object {
                    "description": String("Caption language as a BCP-47 tag (`\"en\"`, `\"en-US\"`, `\"de\"`, …)."),
                    "type": String("string"),
                },
                "video_id": Object {
                    "description": String("The YouTube video ID the transcript belongs to."),
                    "type": String("string"),
                },
            },
            "required": Array [
                String("video_id"),
                String("language"),
                String("entries"),
            ],
            "title": String("Transcript"),
            "type": String("object"),
        },
        timeout_ms: 10000,
        source: Bridge {
            app_kind: "browser",
        },
        required_contexts: [
            "youtube::watch_page",
        ],
        requires_user_approval: false,
    },
    WireToolDescriptor {
        definition: ToolDefinition {
            name: "browser::youtube::get_current_frame",
            description: "Capture the current visible video frame as a PNG, base64-encoded.",
            parameters: Object {
                "$schema": String("https://json-schema.org/draft/2020-12/schema"),
                "description": String("No arguments."),
                "title": String("Empty"),
                "type": String("object"),
            },
        },
        output_schema: Object {
            "$schema": String("https://json-schema.org/draft/2020-12/schema"),
            "description": String("A single captured frame from the active YouTube video."),
            "properties": Object {
                "height": Object {
                    "description": String("Decoded frame height in pixels."),
                    "format": String("uint32"),
                    "minimum": Number(0),
                    "type": String("integer"),
                },
                "image_base64": Object {
                    "description": String("PNG bytes, base64-encoded (standard alphabet, padded)."),
                    "type": String("string"),
                },
                "timestamp_seconds": Object {
                    "description": String("Playback position at which the frame was captured, in seconds."),
                    "format": String("double"),
                    "type": String("number"),
                },
                "video_id": Object {
                    "description": String("The YouTube video ID the frame was captured from."),
                    "type": String("string"),
                },
                "width": Object {
                    "description": String("Decoded frame width in pixels."),
                    "format": String("uint32"),
                    "minimum": Number(0),
                    "type": String("integer"),
                },
            },
            "required": Array [
                String("video_id"),
                String("timestamp_seconds"),
                String("width"),
                String("height"),
                String("image_base64"),
            ],
            "title": String("CapturedFrame"),
            "type": String("object"),
        },
        timeout_ms: 5000,
        source: Bridge {
            app_kind: "browser",
        },
        required_contexts: [
            "youtube::watch_page",
        ],
        requires_user_approval: false,
    },
]
